# ============================================================
#  Metronix — Smart Urban Life Assistant
#  .env.example — Environment Variables Template
#  Author: Ravi Kumar | Roll No: 25CSM1R17
#
#  INSTRUCTIONS:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in all values marked with <YOUR_VALUE>
#    3. NEVER commit .env to version control!
#    4. Generate secrets: openssl rand -hex 32
# ============================================================


# ──────────────────────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────────────────────
NODE_ENV=development                     # development | production | test
APP_NAME=Metronix
APP_VERSION=2.0.0
APP_URL=http://localhost:3000
API_URL=http://localhost:5000/api/v1

# Production URLs (used by docker-compose.prod.yml)
PROD_API_URL=https://api.metronix.app/api/v1
PROD_WS_URL=wss://api.metronix.app


# ──────────────────────────────────────────────────────────────
# BACKEND SERVER
# ──────────────────────────────────────────────────────────────
PORT=5000
LOG_LEVEL=debug                          # error | warn | info | debug
TRUST_PROXY=false                        # Set true behind Nginx
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_WINDOW_MS=900000             # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100            # Per window per IP
BODY_SIZE_LIMIT=10mb


# ──────────────────────────────────────────────────────────────
# POSTGRESQL (Relational Database)
# ──────────────────────────────────────────────────────────────
POSTGRES_DB=metronix
POSTGRES_USER=metronix_user
POSTGRES_PASSWORD=<YOUR_STRONG_POSTGRES_PASSWORD>
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://metronix_user:<YOUR_STRONG_POSTGRES_PASSWORD>@localhost:5432/metronix

# Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000


# ──────────────────────────────────────────────────────────────
# MONGODB (Document Database — City data, reports)
# ──────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=<YOUR_STRONG_MONGO_PASSWORD>
MONGO_DB=metronix
MONGODB_URI=mongodb://admin:<YOUR_STRONG_MONGO_PASSWORD>@localhost:27017/metronix?authSource=admin


# ──────────────────────────────────────────────────────────────
# REDIS (Cache + Pub/Sub + Sessions)
# ──────────────────────────────────────────────────────────────
REDIS_PASSWORD=<YOUR_STRONG_REDIS_PASSWORD>
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Cache TTLs (seconds)
REDIS_TTL_TRAFFIC=300            # 5 minutes
REDIS_TTL_AIR_QUALITY=900        # 15 minutes
REDIS_TTL_SAFETY=900             # 15 minutes
REDIS_TTL_WEATHER=1800           # 30 minutes
REDIS_TTL_USER_SESSION=604800    # 7 days


# ──────────────────────────────────────────────────────────────
# INFLUXDB (Time-Series — Energy & Sensor Data)
# ──────────────────────────────────────────────────────────────
INFLUX_USERNAME=admin
INFLUX_PASSWORD=<YOUR_STRONG_INFLUX_PASSWORD>
INFLUX_ORG=metronix
INFLUX_BUCKET=city_data
INFLUX_TOKEN=<YOUR_INFLUX_ADMIN_TOKEN>
INFLUX_URL=http://localhost:8086


# ──────────────────────────────────────────────────────────────
# JWT AUTHENTICATION
# ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
JWT_SECRET=<YOUR_SUPER_LONG_RANDOM_256BIT_SECRET>
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=<YOUR_DIFFERENT_RANDOM_REFRESH_SECRET>
JWT_REFRESH_EXPIRES_IN=30d

# Cookie settings
COOKIE_SECRET=<YOUR_COOKIE_SECRET>
COOKIE_DOMAIN=localhost


# ──────────────────────────────────────────────────────────────
# OAUTH — GOOGLE
# ──────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=<YOUR_GOOGLE_CLIENT_ID>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<YOUR_GOOGLE_CLIENT_SECRET>
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback


# ──────────────────────────────────────────────────────────────
# MAPS & GEOSPATIAL APIs
# ──────────────────────────────────────────────────────────────

# Mapbox — Interactive maps (Frontend)
# Get from: https://account.mapbox.com
VITE_MAPBOX_TOKEN=pk.<YOUR_MAPBOX_PUBLIC_TOKEN>

# Google Maps — Geocoding, Directions, Places
# Get from: https://console.cloud.google.com
VITE_GOOGLE_MAPS_KEY=<YOUR_GOOGLE_MAPS_API_KEY>
GOOGLE_MAPS_KEY=<YOUR_GOOGLE_MAPS_API_KEY>     # Server-side

# TomTom — Real-time Traffic
# Get from: https://developer.tomtom.com
TOMTOM_TRAFFIC_KEY=<YOUR_TOMTOM_API_KEY>

# HERE Maps — Alternative routing
# Get from: https://developer.here.com
HERE_API_KEY=<YOUR_HERE_API_KEY>


# ──────────────────────────────────────────────────────────────
# AIR QUALITY APIs
# ──────────────────────────────────────────────────────────────

# OpenWeatherMap — Weather + AQ forecast
# Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=<YOUR_OPENWEATHER_API_KEY>

# IQAir (AirVisual) — Global AQI data
# Get from: https://www.iqair.com/air-pollution-data-api
IQAIR_API_KEY=<YOUR_IQAIR_API_KEY>

# AirVisual Node
AIRVISUAL_API_KEY=<YOUR_AIRVISUAL_API_KEY>

# WAQI — World Air Quality Index
# Get from: https://aqicn.org/data-platform/token
WAQI_TOKEN=<YOUR_WAQI_TOKEN>

# Ambee — Pollen and microclimate
# Get from: https://api.ambeedata.com
AMBEE_API_KEY=<YOUR_AMBEE_API_KEY>


# ──────────────────────────────────────────────────────────────
# SAFETY & CRIME DATA APIs
# ──────────────────────────────────────────────────────────────

# data.police.uk — UK Crime Data
POLICE_UK_API_URL=https://data.police.uk/api

# CrimeReports API
CRIME_REPORTS_API_KEY=<YOUR_CRIME_REPORTS_API_KEY>

# Local city data API (configure based on your city)
CITY_DATA_API_URL=<YOUR_CITY_OPEN_DATA_API>
CITY_DATA_API_KEY=<YOUR_CITY_DATA_API_KEY>


# ──────────────────────────────────────────────────────────────
# ENERGY DATA APIs
# ──────────────────────────────────────────────────────────────

# Smart Meter API (configure based on provider)
SMART_METER_API_URL=<YOUR_SMART_METER_API_URL>
SMART_METER_API_KEY=<YOUR_SMART_METER_API_KEY>

# Electricity Map — Carbon intensity
# Get from: https://www.electricitymap.org
ELECTRICITY_MAP_TOKEN=<YOUR_ELECTRICITY_MAP_TOKEN>

# Energy tariff (INR per kWh — adjust for your state)
ENERGY_TARIFF_INR=8.50
PEAK_TARIFF_INR=12.00
OFF_PEAK_TARIFF_INR=5.50


# ──────────────────────────────────────────────────────────────
# NOTIFICATION SERVICES
# ──────────────────────────────────────────────────────────────

# Email — SendGrid
# Get from: https://sendgrid.com
SENDGRID_API_KEY=SG.<YOUR_SENDGRID_API_KEY>
EMAIL_FROM=noreply@metronix.app
EMAIL_FROM_NAME=Metronix

# Push Notifications — Firebase Cloud Messaging
# Get from: https://console.firebase.google.com
FCM_SERVER_KEY=<YOUR_FCM_SERVER_KEY>
FCM_PROJECT_ID=<YOUR_FIREBASE_PROJECT_ID>
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<YOUR_FCM_PRIVATE_KEY>\n-----END PRIVATE KEY-----\n"
FCM_CLIENT_EMAIL=firebase-adminsdk-xxxxx@<YOUR_PROJECT>.iam.gserviceaccount.com

# SMS — Twilio (optional)
# Get from: https://www.twilio.com
TWILIO_ACCOUNT_SID=<YOUR_TWILIO_ACCOUNT_SID>
TWILIO_AUTH_TOKEN=<YOUR_TWILIO_AUTH_TOKEN>
TWILIO_PHONE_NUMBER=+1<YOUR_TWILIO_NUMBER>


# ──────────────────────────────────────────────────────────────
# ML SERVICE (FastAPI — Python)
# ──────────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_PORT=8000
ML_MODEL_PATH=./saved_models
ML_WORKERS=2
ML_LOG_LEVEL=info

# Feature store
FEATURE_STORE_REDIS_DB=1

# Model versions (for blue/green deployments)
TRAFFIC_MODEL_VERSION=v1.2.0
AIR_QUALITY_MODEL_VERSION=v1.0.5
SAFETY_MODEL_VERSION=v1.1.0
ENERGY_MODEL_VERSION=v1.0.3


# ──────────────────────────────────────────────────────────────
# WEBSOCKET
# ──────────────────────────────────────────────────────────────
WS_PING_INTERVAL=25000          # 25 seconds
WS_PING_TIMEOUT=20000           # 20 seconds
WS_MAX_CONNECTIONS=10000


# ──────────────────────────────────────────────────────────────
# FILE STORAGE
# ──────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local           # local | s3 | gcs
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10mb

# AWS S3 (if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_KEY>
AWS_REGION=ap-south-1
AWS_S3_BUCKET=metronix-uploads

# Google Cloud Storage (if STORAGE_PROVIDER=gcs)
GCS_PROJECT_ID=<YOUR_GCS_PROJECT_ID>
GCS_BUCKET=metronix-uploads
GCS_KEYFILE_PATH=./config/gcs-keyfile.json


# ──────────────────────────────────────────────────────────────
# MONITORING & OBSERVABILITY
# ──────────────────────────────────────────────────────────────
# Sentry — Error tracking
SENTRY_DSN=https://<YOUR_SENTRY_KEY>@sentry.io/<YOUR_PROJECT_ID>
SENTRY_ENVIRONMENT=development

# Prometheus metrics endpoint
METRICS_ENABLED=true
METRICS_PORT=9090

# Slack notifications (DevOps)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<YOUR_SLACK_WEBHOOK>


# ──────────────────────────────────────────────────────────────
# DEV TOOLS (docker-compose.yml only)
# ──────────────────────────────────────────────────────────────
ME_USERNAME=admin
ME_PASSWORD=<YOUR_MONGO_EXPRESS_PASSWORD>
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASS=<YOUR_REDIS_COMMANDER_PASSWORD>


# ──────────────────────────────────────────────────────────────
# SECURITY
# ──────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12               # Recommended: 10–14
ENCRYPTION_KEY=<32_BYTE_HEX_KEY_FOR_AES_256>
HELMET_ENABLED=true
CSP_ENABLED=true

# IP Allow/Block list (comma-separated, optional)
IP_ALLOWLIST=
IP_BLOCKLIST=

# Admin access
ADMIN_EMAIL=admin@metronix.app
ADMIN_PASSWORD=<YOUR_ADMIN_PASSWORD>

# ──────────────────────────────────────────────────────────────
# MISC
# ──────────────────────────────────────────────────────────────
TZ=Asia/Kolkata                  # Timezone (IST)
DEFAULT_CITY=New Delhi
DEFAULT_LAT=28.6139
DEFAULT_LNG=77.2090
SUPPORTED_CITIES=Delhi,Mumbai,Bangalore,Chennai,Hyderabad,Pune,Kolkata
